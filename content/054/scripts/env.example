# Copy to .env and fill in before `docker compose up`.

# Shared secret between trynet-control and trynet-ui.
TRYNET_ADMIN_TOKEN=change-me-to-a-long-random-string

# What clients should be told to use as a relay. Usually wss:// + your public hostname.
TRYNET_DERP_URL=ws://your-vps.example.com:3478/relay

# Optional HTTP basic-auth in front of the UI.
TRYNET_UI_USER=admin
TRYNET_UI_PASS=change-me
