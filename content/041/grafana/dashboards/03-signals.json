{
  "uid": "cockpit-signals",
  "title": "OTel Cockpit · Signals Deep Dive",
  "tags": ["otel", "cockpit", "red", "signals"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(up{job=\"collector-app\"}, instance)", "refId": "v" },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(otelpoc_spans_total, service_name)", "refId": "v" },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 100, "type": "row", "title": "Top services", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },

    {
      "id": 1, "type": "bargauge", "title": "Top services · spans /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 9 },
      "targets": [{ "refId": "A", "expr": "topk(10, sum by (service_name) (rate(otelpoc_spans_total{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])))", "legendFormat": "{{service_name}}", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "color": { "mode": "continuous-GrYlRd" } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "valueMode": "color", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "bargauge", "title": "Top services · errors /min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 9 },
      "targets": [{ "refId": "A", "expr": "topk(10, sum by (service_name) (rate(otelpoc_spans_errors_total{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])) * 60)", "legendFormat": "{{service_name}}", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "color": { "mode": "continuous-BlYlRd" } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "valueMode": "color", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } }
    },

    { "id": 101, "type": "row", "title": "RED metrics · spanmetrics", "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 } },

    {
      "id": 10, "type": "timeseries", "title": "Request rate /s  ·  by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 11, "w": 8, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{service_name}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Error rate %  ·  by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 11, "w": 8, "h": 8 },
      "targets": [{ "refId": "A", "expr": "100 * (sum by (service_name) (rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\",instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])) / clamp_min(sum by (service_name) (rate(traces_spanmetrics_calls_total{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])), 0.0001))", "legendFormat": "{{service_name}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 15, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12, "type": "timeseries", "title": "Duration p50 / p95 / p99  ·  aggregate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 11, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_duration_milliseconds_bucket{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_duration_milliseconds_bucket{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_duration_milliseconds_bucket{instance=~\"$instance\",service_name=~\"$service\"}[$__rate_interval])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.6, "fillOpacity": 0, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 102, "type": "row", "title": "Logs", "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 } },

    {
      "id": 20, "type": "timeseries", "title": "Logs /s  ·  by severity (stacked)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (severity_bucket) (rate(otelpoc_logs_by_severity_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{severity_bucket}}" }],
      "fieldConfig": {
        "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "info" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "warn" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 21, "type": "piechart", "title": "Logs mix · by severity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (severity_bucket) (otelpoc_logs_by_severity_total{instance=~\"$instance\"})", "legendFormat": "{{severity_bucket}}" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "info" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "warn" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "pieType": "donut", "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "legend": { "displayMode": "list", "placement": "right", "values": ["value", "percent"] }, "displayLabels": ["percent"], "tooltip": { "mode": "single" } }
    },

    { "id": 103, "type": "row", "title": "Service topology (servicegraph)", "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 } },

    {
      "id": 30, "type": "timeseries", "title": "Request edges  ·  client → server /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (client, server) (rate(traces_service_graph_request_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{client}} → {{server}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 31, "type": "timeseries", "title": "Failed edges /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (client, server) (rate(traces_service_graph_request_failed_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{client}} → {{server}}" }],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80 }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 104, "type": "row", "title": "Synthetic · HTTP check", "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 } },

    {
      "id": 40, "type": "timeseries", "title": "HTTP check  ·  status by class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 38, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (http_status_class, http_url) (httpcheck_status{instance=~\"$instance\"})", "legendFormat": "{{http_url}} · {{http_status_class}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 15, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 41, "type": "timeseries", "title": "HTTP check  ·  duration ms",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 38, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "avg by (http_url) (httpcheck_duration{instance=~\"$instance\"})", "legendFormat": "{{http_url}}" }],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 105, "type": "row", "title": "Host metrics (collector container)", "gridPos": { "x": 0, "y": 46, "w": 24, "h": 1 } },

    {
      "id": 50, "type": "timeseries", "title": "CPU utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 47, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "avg by (instance) (rate(system_cpu_time_seconds_total{instance=~\"$instance\",state!=\"idle\"}[$__rate_interval])) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 51, "type": "timeseries", "title": "Memory used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 47, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "avg by (instance) (system_memory_utilization{instance=~\"$instance\",state=\"used\"}) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "max": 100, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 15, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 52, "type": "timeseries", "title": "Load average 1m",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 47, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "avg by (instance) (system_cpu_load_average_1m{instance=~\"$instance\"})", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 5, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 53, "type": "timeseries", "title": "Network I/O bytes /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 47, "w": 6, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (instance) (rate(system_network_io_bytes_total{instance=~\"$instance\",direction=\"receive\"}[$__rate_interval]))", "legendFormat": "{{instance}} rx" },
        { "refId": "B", "expr": "-sum by (instance) (rate(system_network_io_bytes_total{instance=~\"$instance\",direction=\"transmit\"}[$__rate_interval]))", "legendFormat": "{{instance}} tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 15, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
