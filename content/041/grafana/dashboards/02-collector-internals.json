{
  "uid": "cockpit-internals",
  "title": "OTel Cockpit · Collector Internals",
  "tags": ["otel", "cockpit", "internals"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(up{job=\"collector-app\"}, instance)", "refId": "v" },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 100, "type": "row", "title": "Receivers", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },

    {
      "id": 1, "type": "timeseries", "title": "Receiver accepted /s  ·  by signal",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_receiver_accepted_spans_total{instance=~\"$instance\"}[$__rate_interval]))",        "legendFormat": "spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_receiver_accepted_log_records_total{instance=~\"$instance\"}[$__rate_interval]))",  "legendFormat": "logs" },
        { "refId": "C", "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))","legendFormat": "metrics" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "spans" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "logs" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-blue" } }] },
          { "matcher": { "id": "byName", "options": "metrics" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2, "type": "timeseries", "title": "Receiver refused /s",
      "description": "Refused events indicate backpressure from memory_limiter or downstream components.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_receiver_refused_spans_total{instance=~\"$instance\"}[$__rate_interval]))",        "legendFormat": "spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_receiver_refused_log_records_total{instance=~\"$instance\"}[$__rate_interval]))",  "legendFormat": "logs" },
        { "refId": "C", "expr": "sum(rate(otelcol_receiver_refused_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))","legendFormat": "metrics" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3, "type": "timeseries", "title": "Receiver failed /s",
      "description": "Failed events show unrecoverable errors at ingest (serialization, OTLP decode, etc).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_receiver_failed_spans_total{instance=~\"$instance\"}[$__rate_interval]))",        "legendFormat": "spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_receiver_failed_log_records_total{instance=~\"$instance\"}[$__rate_interval]))",  "legendFormat": "logs" },
        { "refId": "C", "expr": "sum(rate(otelcol_receiver_failed_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))","legendFormat": "metrics" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 101, "type": "row", "title": "Processors", "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 } },

    {
      "id": 10, "type": "timeseries", "title": "Processor throughput  ·  incoming vs outgoing",
      "description": "Large gap = items stuck. Tracks backpressure across processors.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_processor_incoming_items_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "incoming" },
        { "refId": "B", "expr": "sum(rate(otelcol_processor_outgoing_items_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "outgoing" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11, "type": "heatmap", "title": "Batch processor  ·  send size heatmap",
      "description": "Distribution of items per batch at flush. Tighter distribution = predictable latency.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (le) (rate(otelcol_processor_batch_batch_send_size_bucket{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": { "custom": { "scaleDistribution": { "type": "linear" }, "hideFrom": { "tooltip": false, "viz": false, "legend": false } } } },
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "Turbo", "steps": 64, "reverse": false, "fill": "dark-blue", "exponent": 0.5, "min": 0 },
        "legend": { "show": true },
        "tooltip": { "show": true, "yHistogram": false }
      }
    },
    {
      "id": 12, "type": "timeseries", "title": "Batch timeout triggers /s",
      "description": "Timeout-driven flushes (vs size-driven). High value = low traffic or small batches.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum by (instance) (rate(otelcol_processor_batch_timeout_trigger_send_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 102, "type": "row", "title": "Exporters", "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 } },

    {
      "id": 20, "type": "timeseries", "title": "Exporter sent /s  ·  by signal",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_exporter_sent_spans_total{instance=~\"$instance\"}[$__rate_interval]))",        "legendFormat": "spans" },
        { "refId": "B", "expr": "sum(rate(otelcol_exporter_sent_log_records_total{instance=~\"$instance\"}[$__rate_interval]))",  "legendFormat": "logs" },
        { "refId": "C", "expr": "sum(rate(otelcol_exporter_sent_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))","legendFormat": "metrics" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "spans" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "logs" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-blue" } }] },
          { "matcher": { "id": "byName", "options": "metrics" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 21, "type": "timeseries", "title": "Pipeline loss  ·  accepted - sent (metric points)",
      "description": "Positive = items accepted but never exported (dropped in processors/connectors/exporters).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "targets": [{ "refId": "A", "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total{instance=~\"$instance\"}[$__rate_interval])) - sum(rate(otelcol_exporter_sent_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "accept−sent (metrics)" }],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    { "id": 103, "type": "row", "title": "Process · runtime", "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 } },

    {
      "id": 30, "type": "timeseries", "title": "CPU  ·  collector process",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "rate(otelcol_process_cpu_seconds_total{instance=~\"$instance\"}[$__rate_interval]) * 100", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 31, "type": "timeseries", "title": "Memory RSS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "otelcol_process_memory_rss_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 20, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 32, "type": "timeseries", "title": "Heap alloc",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "otelcol_process_runtime_heap_alloc_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 15, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 33, "type": "stat", "title": "Uptime (max)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 8 },
      "targets": [{ "refId": "A", "expr": "max by (instance) (otelcol_process_uptime_seconds_total{instance=~\"$instance\"})", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "values": true, "calcs": ["lastNotNull"] }, "orientation": "vertical" }
    },

    { "id": 104, "type": "row", "title": "Connectors", "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 } },

    {
      "id": 40, "type": "timeseries", "title": "servicegraph  ·  edges observed /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(otelcol_connector_servicegraph_total_edges_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "edges total" },
        { "refId": "B", "expr": "sum(rate(otelcol_connector_servicegraph_expired_edges_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "edges expired" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 41, "type": "timeseries", "title": "scraper  ·  scraped metric points /s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum by (scraper) (rate(otelcol_scraper_scraped_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{scraper}}" },
        { "refId": "B", "expr": "sum by (scraper) (rate(otelcol_scraper_errored_metric_points_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{scraper}} (errored)" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "decimals": 2, "custom": { "drawStyle": "line", "lineWidth": 1.4, "fillOpacity": 10, "showPoints": "never" }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
