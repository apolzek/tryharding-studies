{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "RED metrics (Rate, Errors, Duration) produced by OpenTelemetry zero-code auto-instrumentation + spanmetrics connector",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "id": 100,
      "title": "Total request rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[$__rate_interval]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "title": "Error rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum(rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[$__rate_interval])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "title": "p95 latency (service-wide)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "title": "Active series (span_name cardinality)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "expr": "count(count by (span_name) (traces_spanmetrics_calls_total{service_name=~\"$service\"}))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "title": "Rate — requests/s per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "mean"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 201,
      "title": "Errors — errors/s per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "title": "Duration — p50 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 301,
      "title": "Duration — p95 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 302,
      "title": "Duration — p99 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{span_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 400,
      "title": "Latency distribution (heatmap)",
      "type": "heatmap",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "ms" },
        "color": { "scheme": "Spectral", "mode": "scheme", "exponent": 0.5 }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 500,
      "title": "Top endpoints — table",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "refId": "A",
          "legendFormat": "rate"
        },
        {
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / clamp_min(sum by (span_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[$__rate_interval])), 1e-9)",
          "format": "table",
          "instant": true,
          "refId": "B",
          "legendFormat": "error_rate"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(traces_spanmetrics_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "format": "table",
          "instant": true,
          "refId": "C",
          "legendFormat": "p95_ms"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "service_name": true },
            "renameByName": {
              "Value #A": "rate (req/s)",
              "Value #B": "error rate",
              "Value #C": "p95 (ms)"
            }
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["red", "spanmetrics", "otel"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(traces_spanmetrics_calls_total, service_name)", "refId": "StandardVariableQuery" },
        "current": { "selected": false, "text": "demo-app", "value": "demo-app" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RED — OTel auto-instrumentation (spanmetrics)",
  "uid": "red-otel-spanmetrics",
  "version": 1,
  "weekStart": ""
}
