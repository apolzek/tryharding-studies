{
  "annotations": { "list": [] },
  "description": "RED metrics (Rate, Errors, Duration) from native OTel SDK HTTP server metrics — emitted directly by the application SDK, not derived from spans",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "id": 100,
      "title": "Total request rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "title": "Error rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{service_name=~\"$service\",http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "title": "p95 latency (service-wide)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "title": "In-flight requests (SDK gauge)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "expr": "sum(http_server_active_requests{service_name=~\"$service\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "title": "Rate — req/s by route & method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "mean"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (http_method, http_target) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{http_method}} {{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 201,
      "title": "Status codes — req/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{http_status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "title": "Duration — p50 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 301,
      "title": "Duration — p95 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 302,
      "title": "Duration — p99 per route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 400,
      "title": "Latency distribution (heatmap)",
      "type": "heatmap",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "ms" },
        "color": { "scheme": "Spectral", "mode": "scheme", "exponent": 0.5 }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 500,
      "title": "Top endpoints — table",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } } },
      "options": { "showHeader": true },
      "targets": [
        {
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\",http_status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (http_target) (rate(http_server_duration_milliseconds_count{service_name=~\"$service\"}[$__rate_interval])), 1e-9)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_target) (rate(http_server_duration_milliseconds_bucket{service_name=~\"$service\"}[$__rate_interval])))",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "service_name": true },
            "renameByName": {
              "Value #A": "rate (req/s)",
              "Value #B": "error rate (5xx)",
              "Value #C": "p95 (ms)"
            }
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["red", "native", "otel", "sdk"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(http_server_duration_milliseconds_count, service_name)", "refId": "StandardVariableQuery" },
        "current": { "selected": false, "text": "demo-app", "value": "demo-app" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RED — OTel native SDK (http.server)",
  "uid": "red-otel-native",
  "version": 1,
  "weekStart": ""
}
