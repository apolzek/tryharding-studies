. {
    log
    errors
    prometheus :9153
    cache 30

    # Zona local com registros custom
    file /etc/coredns/db.internal.lab internal.lab

    # Resolve por hosts file (útil para split-horizon)
    hosts /etc/coredns/hosts {
        fallthrough
    }

    # Forward para resolver upstream
    forward . 1.1.1.1 8.8.8.8
}
