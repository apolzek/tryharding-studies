# -------- General --------
PORT=3000
# Base URL used for OAuth redirect URIs. Set to http://localhost:3000 for local dev.
APP_URL=http://localhost:3000
# Publicly reachable URL (e.g. ngrok tunnel). REQUIRED for Instagram (IG fetches the video from it).
PUBLIC_URL=

# -------- YouTube (Google Cloud Console -> OAuth 2.0 Client ID, type Web) --------
# Authorized redirect URI: ${APP_URL}/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# private | unlisted | public
YOUTUBE_PRIVACY=private

# -------- TikTok (TikTok for Developers -> App with Content Posting API) --------
# Redirect URI: ${APP_URL}/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# SELF_ONLY | MUTUAL_FOLLOW_FRIENDS | FOLLOWER_OF_CREATOR | PUBLIC_TO_EVERYONE
# While the app is in sandbox/unaudited mode TikTok forces SELF_ONLY.
TIKTOK_PRIVACY=SELF_ONLY

# -------- Twitch (dev.twitch.tv -> Applications) --------
# OAuth Redirect URL: ${APP_URL}/api/auth/twitch/callback
# NOTE: Twitch has no public API to upload a VOD. We store the token for future use
# and return a friendly message when posting.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# -------- Meta (Facebook + Instagram share the same app) --------
# developers.facebook.com -> App -> Facebook Login for Business
# Valid OAuth Redirect URIs:
#   ${APP_URL}/api/auth/facebook/callback
#   ${APP_URL}/api/auth/instagram/callback
META_APP_ID=
META_APP_SECRET=

# -------- X / Twitter (developer.x.com) --------
# Project/App with "Read and write" permissions.
# Generate API Key/Secret AND User Access Token/Secret for YOUR account
# (OAuth 1.0a User Context - no OAuth flow needed in the UI).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# -------- LinkedIn (developer.linkedin.com -> Apps) --------
# Products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
# Redirect URL: ${APP_URL}/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
