# =============================================================================
# PoC-031 environment variables
# Copy to .env and adjust as needed before running `make up`.
# =============================================================================

# ---- MinIO (object storage for rrweb session replay chunks) ----------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rrweb-sessions

# ---- Backend API -----------------------------------------------------------
# Backend sends OTLP directly to the collector (http/protobuf).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=backend-api
OTEL_RESOURCE_ATTRIBUTES=service.name=backend-api,deployment.environment=poc

# ---- Grafana ---------------------------------------------------------------
# Anonymous Admin is enabled for POC convenience — do NOT use in production.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin

# ---- Frontends -------------------------------------------------------------
# Faro receiver (Alloy) and direct OTLP/HTTP collector endpoints.
FARO_URL=http://localhost:12347/collect
OTLP_URL=http://localhost:4318

# ---- Compose project name --------------------------------------------------
COMPOSE_PROJECT_NAME=poc-031
