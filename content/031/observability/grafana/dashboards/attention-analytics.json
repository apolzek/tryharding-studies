{
  "uid": "poc031-attention",
  "title": "Attention Analytics",
  "tags": ["poc-031", "attention", "product"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" },
        "hide": 0
      },
      {
        "name": "loki_ds",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" },
        "hide": 0
      },
      {
        "name": "stack",
        "label": "Frontend Stack",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(post_dwell_time_ms_count, frontend_stack)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Post Views (rate sum)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(post_dwell_time_ms_count{frontend_stack=~\"$stack\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Dwell Time p50 / p95 / p99",
      "gridPos": { "h": 9, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(post_dwell_time_ms_bucket{frontend_stack=~\"$stack\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(post_dwell_time_ms_bucket{frontend_stack=~\"$stack\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(post_dwell_time_ms_bucket{frontend_stack=~\"$stack\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Top 10 Posts by Avg Dwell Time",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (post_id) (rate(post_dwell_time_ms_sum{frontend_stack=~\"$stack\"}[10m])) / sum by (post_id) (rate(post_dwell_time_ms_count{frontend_stack=~\"$stack\"}[10m])))",
          "legendFormat": "{{post_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Interactions by Type",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (interaction_type) (rate(post_interactions_total{frontend_stack=~\"$stack\"}[1m]))",
          "legendFormat": "{{interaction_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 5,
      "type": "heatmap",
      "title": "Dwell Time Heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (le) (rate(post_dwell_time_ms_bucket{frontend_stack=~\"$stack\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "scheme": "Spectral", "mode": "scheme", "exponent": 0.5, "steps": 64, "reverse": false },
        "yAxis": { "unit": "ms" },
        "tooltip": { "show": true, "yHistogram": true },
        "legend": { "show": true }
      }
    }
  ]
}
