{
  "uid": "poc031-replay",
  "title": "Session Replay Explorer",
  "tags": ["poc-031", "rrweb", "sessions"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "loki_ds",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "loki" }
      },
      {
        "name": "prom_ds",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Replay Chunks Received",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prom_ds}" },
      "targets": [
        { "expr": "sum(replay_chunks_received_total)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Replay Bytes Stored",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prom_ds}" },
      "targets": [
        { "expr": "sum(replay_bytes_stored_total)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Distinct Sessions (1h)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prom_ds}" },
      "targets": [
        { "expr": "count(count by (session_id) (replay_chunks_received_total))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ingest Rate (chunks/sec)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${prom_ds}" },
      "targets": [
        { "expr": "sum(rate(replay_chunks_received_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent post.view_end events (session_id, user_id, trace_id, dwell_ms)",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "targets": [
        {
          "expr": "{service_name=~\"frontend-.*\"} |= \"post.view_end\" | json | line_format \"{{.session_id}} {{.user_id}} {{.trace_id}} {{.dwell_ms}}\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Backend replay.ingest logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "targets": [
        {
          "expr": "{service_name=\"backend-api\"} |= \"replay.ingest\"",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
